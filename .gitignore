# Local .terraform directories
.terraform/

# .tfstate files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# May contain sensitive data
*.tfvars
*.tfvars.json
# Perhaps you would still like to add something:
!example.auto.tfvars

# Ignore override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json
# Perhaps you would still like to add something:
!example_override.tf

# Ignore transient lock info files
.terraform.tfstate.lock.info

# Include tfplan files: terraform plan -out=tfplan
tfplan

# Ignore CLI configuration files
.terraformrc
terraform.rc

# Custom for s3
s3creds.rc
backend.hcl